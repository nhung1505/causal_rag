    <node id="GIAO_NGUOI_KHONG_DU_DIEU_KIEN_DIEU_KHIEN_DUONG_SAT_KHOAN_1">
      <data key="d0">condition</data>
      <data key="d5">giao cho người không đủ điều kiện điều khiển phương tiện giao thông đường sắt gây thiệt hại cho người khác thuộc một trong các trường hợp quy định tại khoản 1 Điều 271 hoặc đã bị xử lý kỷ luật hoặc xử phạt vi phạm hành chính về hành vi này mà còn vi phạm</data>
