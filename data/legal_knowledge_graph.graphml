    <node id="GAY_THUONG_TICH_NHIEU_NGUOI_TRONG_TRANG_THAI_KICH_DONG_MANH">
      <data key="d0">condition</data>
      <data key="d5">gây thương tích hoặc gây tổn hại sức khỏe cho từ 02 người trở lên trong trạng thái tinh thần bị kích động mạnh mà mỗi người có tỷ lệ tổn thương cơ thể từ 31% trở lên</data>
    </node>
