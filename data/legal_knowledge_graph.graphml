    <node id="SU_DUNG_TRAI_PHEP_CHAT_MA_TUY_KHOAN_1">
      <data key="d0">condition</data>
      <data key="d5">sử dụng trái phép chất ma túy thuộc một trong các trường hợp quy định tại khoản 1 Điều 256a</data>
    </node>
