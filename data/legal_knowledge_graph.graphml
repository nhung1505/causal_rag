    <node id="PHAT_TIEN_HOAC_PHAT_TU_5_10_NAM">
      <data key="d0">effect</data>
      <data key="d5">bị phạt tiền từ 1.000.000.000 đồng đến 3.000.000.000 đồng hoặc phạt tù từ 05 năm đến 10 năm</data>
