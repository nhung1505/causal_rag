    <node id="VI_PHAM_AN_TOAN_THUC_PHAM_KHOAN_1">
      <data key="d0">condition</data>
      <data key="d5">thực hiện hành vi vi phạm quy định về an toàn thực phẩm thuộc khoản 1 Điều 317</data>
