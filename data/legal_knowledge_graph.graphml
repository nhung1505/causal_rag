      <data key="d0">effect</data>
      <data key="d5">tạm dừng hoạt động trong một hoặc một số lĩnh vực</data>
    </node>
    <node id="RULE_341">
      <data key="d0">rule</data>
      <data key="d4">341</data>
    </node>
