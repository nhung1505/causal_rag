    <node id="LOI_DUNG_CHUC_VU_BAO_CHE_TOI_PHAM">
      <data key="d0">condition</data>
      <data key="d5">lợi dụng chức vụ, quyền hạn cản trở việc phát hiện tội phạm hoặc bao che người phạm tội</data>
