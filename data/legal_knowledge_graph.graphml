    <node id="SAN_XUAT_BUON_BAN_HANG_CAM_KHOAN_3">
      <data key="d0">condition</data>
      <data key="d5">sản xuất, buôn bán hàng cấm thuộc trường hợp quy định tại khoản 3 Điều 190</data>
