    <node id="DANH_THAO_TOI_AN_NINH_QUOC_GIA_HOAC_TU_HINH">
      <data key="d0">condition</data>
      <data key="d5">đánh tháo người bị kết án về tội xâm phạm an ninh quốc gia hoặc người bị kết án tử hình</data>
