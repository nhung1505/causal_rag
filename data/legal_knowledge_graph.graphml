    </node>
    <node id="PHAT_TIEN_100_TRIEU_1_TY_HOAC_CAI_TAO_HOAC_PHAT_TU_1_5_NAM">
      <data key="d0">effect</data>
      <data key="d5">bị phạt tiền từ 100.000.000 đồng đến 1.000.000.000 đồng, phạt cải tạo không giam giữ đến 03 năm hoặc phạt tù từ 01 năm đến 05 năm</data>
    </node>
