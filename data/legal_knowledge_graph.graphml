    <node id="SAN_XUAT_BUON_BAN_HANG_GIA_THUOC_CHUA_BENH">
      <data key="d0">condition</data>
      <data key="d5">sản xuất, buôn bán hàng giả là thuốc chữa bệnh, thuốc phòng bệnh</data>
    </node>
    <node id="RULE_704">
