      <data key="d5">thấy trước hành vi của mình có thể gây ra hậu quả nguy hại cho xã hội nhưng cho rằng hậu quả đó sẽ không xảy ra hoặc có thể ngăn ngừa được</data>
    </node>
    <node id="VO_Y_PHAM_TOI">
