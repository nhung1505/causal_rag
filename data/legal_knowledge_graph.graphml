    <node id="TO_CHUC_DUA_XE_TRAI_PHEP_KHOAN_2">
      <data key="d0">condition</data>
      <data key="d5">phạm tội thuộc một trong các trường hợp quy định tại khoản 2 Điều 265</data>
    </node>
    <node id="PHAT_TIEN_HOAC_PHAT_TU_4_10_NAM">
      <data key="d0">effect</data>
      <data key="d5">bị phạt tiền từ 100.000.000 đồng đến 500.000.000 đồng hoặc phạt tù từ 04 năm đến 10 năm</data>
    </node>
