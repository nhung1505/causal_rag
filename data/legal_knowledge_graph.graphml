    <node id="DAO_NHIEM_TRONG_HOAN_CANH_DAC_BIET">
      <data key="d0">condition</data>
      <data key="d5">phạm tội trong hoàn cảnh chiến tranh, thiên tai, dịch bệnh hoặc trường hợp khó khăn đặc biệt khác của xã hội</data>
    </node>
    <node id="RULE_1400">
      <data key="d0">rule</data>
      <data key="d4">1400</data>
    </node>
    <node id="KET_AN_DAO_NHIEM">
