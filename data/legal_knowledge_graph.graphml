      <data key="d5">có hành vi phạm tội ở ngoài lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam và hành vi đó được Bộ luật Hình sự quy định là tội phạm</data>
    </node>
    <node id="CO_THE_BI_TRUY_CUU_TNHS">
      <data key="d0">effect</data>
      <data key="d5">có thể bị truy cứu trách nhiệm hình sự tại Việt Nam</data>
    </node>
    <node id="RULE_20">
      <data key="d0">rule</data>
