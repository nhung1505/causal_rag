    </node>
    <node id="SUBJECT_NGƯỜI_CÓ_CÔNG_VỚI_CÁCH_MẠNG_THÂN_NHÂN_NGƯỜI_CÓ_CÔNG_VỚI_CÁCH_MẠNG_NGƯỜI_DỦ_70_TUỔI_TRỞ_LÊN_NGƯỜI_KHUYẾT_TẬT_NẶNG_HOẶC_DẶC_BIỆT_NẶNG_PHỤ_NỮ_DANG_NUÔI_CON_DƯỚI_36_THÁNG_TUỔI">
