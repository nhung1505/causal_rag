    <node id="CAN_TRO_TAU_TAN_50_200_TRIEU">
      <data key="d0">condition</data>
      <data key="d5">dẫn đến tẩu tán tài sản và không thi hành được nghĩa vụ từ 50.000.000 đồng đến dưới 200.000.000 đồng</data>
    </node>
    <node id="RULE_1568">
      <data key="d0">rule</data>
      <data key="d4">1568</data>
    </node>
