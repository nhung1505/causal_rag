      <data key="d4">326</data>
    </node>
    <node id="SUBJECT_NGƯỜI_DƯỢC_MIỄN_CHẤP_HÀNH_PHẦN_HÌNH_PHẠT_CÒN_LẠI">
      <data key="d0">subject</data>
      <data key="d5">người được miễn chấp hành phần hình phạt còn lại</data>
    </node>
    <node id="DUOC_MIEN_CHAP_HANH_PHAN_HINH_PHAT_CON_LAI">
