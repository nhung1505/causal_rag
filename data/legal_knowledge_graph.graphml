      <data key="d5">bị áp dụng hình phạt tiền</data>
    </node>
    <node id="PHAT_TIEN_HINH_PHAT_CHINH">
      <data key="d0">effect</data>
      <data key="d5">phạt tiền là hình phạt chính</data>
    </node>
