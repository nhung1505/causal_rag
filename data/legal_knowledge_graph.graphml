      <data key="d0">condition</data>
      <data key="d5">phạm tội thuộc một trong các trường hợp quy định tại khoản 2 Điều 213</data>
    </node>
    <node id="RULE_756">
      <data key="d0">rule</data>
      <data key="d4">756</data>
