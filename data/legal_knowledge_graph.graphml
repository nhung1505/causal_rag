      <data key="d0">rule</data>
      <data key="d4">1214</data>
    </node>
    <node id="LOI_DUNG_CHUC_VU_XAM_PHAM_BI_MAT_NHA_NUOC">
      <data key="d0">condition</data>
      <data key="d5">lợi dụng chức vụ, quyền hạn để cố ý làm lộ hoặc chiếm đoạt bí mật nhà nước</data>
    </node>
    <node id="RULE_1215">
      <data key="d0">rule</data>
      <data key="d4">1215</data>
    </node>
