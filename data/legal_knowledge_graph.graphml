      <data key="d0">condition</data>
      <data key="d5">sử dụng trái phép tài sản thuộc trường hợp quy định tại khoản 2 Điều 177</data>
    </node>
    <node id="PHAT_TIEN_HOAC_PHAT_TU_1_5_NAM">
      <data key="d0">effect</data>
      <data key="d5">bị phạt tiền từ 50.000.000 đồng đến 100.000.000 đồng hoặc phạt tù từ 01 năm đến 05 năm</data>
    </node>
    <node id="RULE_660">
      <data key="d0">rule</data>
      <data key="d4">660</data>
    </node>
    <node id="SU_DUNG_TRAI_PHEP_TAI_SAN_TREN_1_5_TY">
      <data key="d0">condition</data>
      <data key="d5">sử dụng trái phép tài sản trị giá từ 1.500.000.000 đồng trở lên</data>
    </node>
