      <data key="d0">condition</data>
      <data key="d5">gây tổn hại về quốc phòng, an ninh, đối ngoại, kinh tế hoặc văn hóa</data>
    </node>
    <node id="RULE_1216">
      <data key="d0">rule</data>
      <data key="d4">1216</data>
    </node>
    <node id="TO_CHUC_XAM_PHAM_BI_MAT_NHA_NUOC">
      <data key="d0">condition</data>
      <data key="d5">có tổ chức khi phạm tội xâm phạm bí mật nhà nước</data>
    </node>
    <node id="RULE_1217">
      <data key="d0">rule</data>
      <data key="d4">1217</data>
    </node>
    <node id="BI_MAT_NHA_NUOC_DO_TUYET_MAT">
      <data key="d0">condition</data>
      <data key="d5">bí mật nhà nước thuộc độ tuyệt mật</data>
    </node>
