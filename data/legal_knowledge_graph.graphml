      <data key="d0">condition</data>
      <data key="d5">phạm tội với tiền giả có trị giá tương ứng từ 5.000.000 đồng đến dưới 50.000.000 đồng</data>
    </node>
    <node id="RULE_740">
      <data key="d0">rule</data>
      <data key="d4">740</data>
    </node>
