      <data key="d0">subject</data>
      <data key="d5">người bị địch bắt làm tù binh</data>
    </node>
    <node id="KHAI_BAO_BI_MAT_HOAC_TU_NGUYEN_LAM_VIEC_CHO_DICH">
      <data key="d0">condition</data>
      <data key="d5">khai báo bí mật công tác quân sự hoặc tự nguyện làm việc cho địch</data>
    </node>
    <node id="RULE_1671">
