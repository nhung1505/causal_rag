      <data key="d4">1608</data>
    </node>
    <node id="SUBJECT_NGƯỜI_KHÔNG_TỐ_GIÁC">
      <data key="d0">subject</data>
      <data key="d5">người không tố giác</data>
    </node>
    <node id="CAN_NGAN_HOAC_HAN_CHE_TAC_HAI_TOI_PHAM">
      <data key="d0">condition</data>
      <data key="d5">đã can ngăn người phạm tội hoặc hạn chế tác hại của tội phạm</data>
    </node>
