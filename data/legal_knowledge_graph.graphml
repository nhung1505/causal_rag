      <data key="d0">rule</data>
      <data key="d4">185</data>
    </node>
    <node id="TU_NGUYEN_KHAC_PHUC_HAU_QUA">
      <data key="d0">condition</data>
      <data key="d5">tự nguyện sửa chữa, bồi thường thiệt hại hoặc khắc phục hậu quả</data>
    </node>
