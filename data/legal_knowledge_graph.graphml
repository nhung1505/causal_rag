    <node id="TAU_TAN_TAI_SAN_TREN_100_TRIEU">
      <data key="d0">condition</data>
      <data key="d5">dẫn đến bị can, bị cáo, người bị kết án, người phải thi hành án hoặc người có nghĩa vụ thi hành án tẩu tán tài sản và không thi hành được nghĩa vụ thi hành án với số tiền từ 100.000.000 đồng trở lên</data>
    </node>
    <node id="RULE_1590">
      <data key="d0">rule</data>
      <data key="d4">1590</data>
