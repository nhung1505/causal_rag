    <node id="VI_PHAM_DAU_TU_CONG_TRINH_XAY_DUNG_KHOAN_1">
      <data key="d0">condition</data>
      <data key="d5">thực hiện hành vi vi phạm quy định về đầu tư công trình xây dựng thuộc khoản 1 Điều 224 gây thiệt hại từ 100.000.000 đồng đến dưới 300.000.000 đồng hoặc dưới 100.000.000 đồng nhưng đã bị xử lý kỷ luật về hành vi này mà còn vi phạm</data>
    </node>
