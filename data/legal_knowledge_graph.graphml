    <node id="ARTICLE_76">
      <data key="d0">article</data>
      <data key="d1">76</data>
      <data key="d2">Phạm vi chịu trách nhiệm hình sự của pháp nhân thương mại[30]</data>
      <data key="d3">Điều 76. Phạm vi chịu trách nhiệm hình sự của pháp nhân thương mại[30]
Pháp nhân thương mại phải chịu trách nhiệm hình sự về tội phạm quy định tại một trong các điều 188, 189, 190, 191, 192, 193, 194, 195, 196, 200, 203, 209, 210, 211, 213, 216, 217, 225, 226, 227, 232, 234, 235, 237, 238, 239, 242, 243, 244, 245, 246, 300 và 324 của Bộ luật này.</data>
    </node>
