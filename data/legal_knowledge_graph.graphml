    </node>
    <node id="RULE_110">
      <data key="d0">rule</data>
      <data key="d4">110</data>
    </node>
    <node id="PHAM_TOI_THAM_NHUNG_MA_TUY">
      <data key="d0">condition</data>
      <data key="d5">phạm tội về tham nhũng, ma túy hoặc tội phạm khác do Bộ luật Hình sự quy định</data>
    </node>
    <node id="CO_THE_PHAT_TIEN_BO_SUNG">
      <data key="d0">effect</data>
      <data key="d5">có thể bị áp dụng hình phạt tiền là hình phạt bổ sung</data>
    </node>
    <node id="RULE_111">
      <data key="d0">rule</data>
      <data key="d4">111</data>
    </node>
