    </node>
    <node id="RULE_1614">
      <data key="d0">rule</data>
      <data key="d4">1614</data>
    </node>
    <node id="TRONG_CHIEN_DAU">
      <data key="d0">condition</data>
      <data key="d5">trong chiến đấu</data>
    </node>
