    <node id="PHAT_BO_SUNG_VA_CAM_CU_TRU_1_5_NAM">
      <data key="d0">có thể bị phạt tiền từ 5.000.000 đồng đến 50.000.000 đồng, cấm cư trú từ 01 năm đến 05 năm</data>
    </node>
    <node id="XUAT_NHAP_CANH_HOAC_O_LAI_TRAI_PHEP_TAI_PHAM">
      <data key="d0">xuất cảnh trái phép, nhập cảnh trái phép hoặc ở lại Việt Nam trái phép, đã bị xử phạt vi phạm hành chính về hành vi này mà còn vi phạm</data>
    </node>
    <node id="PHAT_TIEN_5_50_TRIEU_HOAC_PHAT_TU_6_THANG_3_NAM">
