      <data key="d0">khám xét, đuổi, chiếm giữ, cản trở hoặc xâm nhập trái pháp luật chỗ ở của người khác</data>
    </node>
    <node id="CAI_TAO_HOAC_PHAT_TU_3_THANG_2_NAM">
      <data key="d0">bị phạt cải tạo không giam giữ đến 02 năm hoặc phạt tù từ 03 tháng đến 02 năm</data>
    </node>
    <node id="XAM_PHAM_CHO_O_KHUNG_2">
      <data key="d0">xâm phạm chỗ ở của người khác thuộc trường hợp quy định tại khoản 2 Điều 158</data>
    </node>
    <node id="PHAM_TOI_XAM_PHAM_CHO_O">
      <data key="d0">phạm tội xâm phạm chỗ ở của người khác</data>
    </node>
    <node id="XAM_PHAM_BI_MAT_THU_TIN_TAI_PHAM">
      <data key="d0">đã bị xử lý kỷ luật hoặc xử phạt vi phạm hành chính về hành vi xâm phạm bí mật hoặc an toàn thư tín, điện thoại, điện tín hoặc hình thức trao đổi thông tin riêng tư khác mà còn vi phạm</data>
    </node>
    <node id="CANH_CAO_HOAC_PHAT_TIEN_HOAC_CAI_TAO">
      <data key="d0">bị phạt cảnh cáo, phạt tiền từ 5.000.000 đồng đến 50.000.000 đồng hoặc phạt cải tạo không giam giữ đến 02 năm</data>
    </node>
    <node id="XAM_PHAM_BI_MAT_THU_TIN_KHUNG_2">
      <data key="d0">xâm phạm bí mật hoặc an toàn thư tín thuộc trường hợp quy định tại khoản 2 Điều 159</data>
    </node>
    <node id="PHAM_TOI_XAM_PHAM_BI_MAT_THU_TIN">
