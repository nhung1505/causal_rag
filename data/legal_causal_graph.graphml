    <node id="BUOC_THOI_VIEC_HOAC_SA_THAI_TRAI_PHAP_LUAT">
      <data key="d0">vì vụ lợi hoặc động cơ cá nhân khác mà buộc công chức, viên chức thôi việc trái pháp luật, sa thải trái pháp luật người lao động hoặc cưỡng ép, đe dọa buộc thôi việc gây hậu quả nghiêm trọng</data>
    </node>
    <node id="BUOC_THOI_VIEC_HOAC_SA_THAI_TRAI_PHAP_LUAT_KHUNG_2">
      <data key="d0">buộc thôi việc hoặc sa thải trái pháp luật thuộc trường hợp quy định tại khoản 2 Điều 162</data>
    </node>
    <node id="PHAT_TIEN_HOAC_PHAT_TU_1_3_NAM">
      <data key="d0">bị phạt tiền từ 100.000.000 đồng đến 300.000.000 đồng hoặc phạt tù từ 01 năm đến 03 năm</data>
