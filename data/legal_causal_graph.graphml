    </node>
    <node id="CAN_TRO_QUYEN_BAU_CU_UNG_CU">
      <data key="d0">lừa gạt, mua chuộc, cưỡng ép hoặc dùng thủ đoạn khác cản trở công dân thực hiện quyền bầu cử, ứng cử hoặc biểu quyết</data>
    </node>
    <node id="CANH_CAO_HOAC_CAI_TAO_HOAC_PHAT_TU_3_THANG_1_NAM">
      <data key="d0">bị phạt cảnh cáo, phạt cải tạo không giam giữ đến 01 năm hoặc phạt tù từ 03 tháng đến 01 năm</data>
    </node>
    <node id="CAN_TRO_QUYEN_BAU_CU_UNG_CU_KHUNG_2">
      <data key="d0">cản trở quyền bầu cử, ứng cử hoặc biểu quyết thuộc trường hợp quy định tại khoản 2 Điều 160</data>
    </node>
    <node id="PHAT_TU_1_2_NAM">
