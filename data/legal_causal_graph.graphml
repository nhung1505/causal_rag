    </node>
    <node id="LAM_SAI_LECH_KET_QUA_BAU_CU">
      <data key="d0">giả mạo giấy tờ, gian lận phiếu hoặc dùng thủ đoạn khác làm sai lệch kết quả bầu cử hoặc trưng cầu ý dân</data>
    </node>
    <node id="LAM_SAI_LECH_KET_QUA_BAU_CU_KHUNG_2">
      <data key="d0">làm sai lệch kết quả bầu cử hoặc trưng cầu ý dân thuộc trường hợp quy định tại khoản 2 Điều 161</data>
    </node>
