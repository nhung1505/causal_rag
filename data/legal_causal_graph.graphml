  <graph edgedefault="directed">
    <node id="PHAM_TOI">
      <data key="d0">phạm một tội được Bộ luật Hình sự quy định</data>
    </node>
    <node id="CHIU_TRACH_NHIEM_HINH_SU">
      <data key="d0">chịu trách nhiệm hình sự</data>
    </node>
    <node id="PHAM_TOI_PHAP_NHAN">
      <data key="d0">thực hiện hành vi phạm tội thuộc các tội danh quy định tại Điều 76 của Bộ luật Hình sự</data>
    </node>
    <node id="PHAM_TOI_LAN_DAU_IT_NGHIEM_TRONG">
      <data key="d0">phạm tội lần đầu và thuộc trường hợp ít nghiêm trọng</data>
    </node>
    <node id="AP_DUNG_HINH_PHAT_NHE">
      <data key="d0">áp dụng hình phạt nhẹ hơn hình phạt tù</data>
    </node>
    <node id="GIAM_SAT_GIAO_DUC">
      <data key="d0">được giao cho cơ quan, tổ chức hoặc Ủy ban nhân dân cấp xã giám sát, giáo dục</data>
    </node>
    <node id="BI_KET_AN_PHAT_TU">
      <data key="d0">bị phạt tù</data>
    </node>
    <node id="CHAP_HANH_HINH_PHAT_TU">
      <data key="d0">chấp hành hình phạt tại cơ sở giam giữ</data>
    </node>
    <node id="CAI_TAO_GIAO_DUC">
      <data key="d0">lao động và học tập để trở thành người có ích cho xã hội</data>
    </node>
    <node id="DU_DIEU_KIEN_GIAM_AN">
      <data key="d0">có đủ điều kiện theo Bộ luật Hình sự</data>
    </node>
    <node id="GIAM_THOI_HAN_CHAP_HANH">
      <data key="d0">được xét giảm thời hạn chấp hành hình phạt</data>
    </node>
    <node id="DU_DIEU_KIEN_THA_TU">
      <data key="d0">có đủ điều kiện theo Bộ luật Hình sự</data>
    </node>
    <node id="THA_TU_TRUOC_HAN">
      <data key="d0">được tha tù trước thời hạn có điều kiện</data>
    </node>
    <node id="DA_CHAP_HANH_XONG_HINH_PHAT">
      <data key="d0">đã chấp hành xong hình phạt</data>
    </node>
    <node id="TAI_HOA_NHAP_CONG_DONG">
      <data key="d0">được tạo điều kiện làm ăn, sinh sống lương thiện, hòa nhập cộng đồng</data>
    </node>
    <node id="DU_DIEU_KIEN_XOA_AN_TICH">
      <data key="d0">thuộc trường hợp quy định tại Điều 70 đến Điều 73 của Bộ luật Hình sự</data>
    </node>
    <node id="XOA_AN_TICH">
      <data key="d0">đương nhiên được xóa án tích</data>
    </node>
    <node id="HOP_TAC_DIEU_TRA">
      <data key="d0">tích cực hợp tác với cơ quan có trách nhiệm trong việc phát hiện tội phạm hoặc giải quyết vụ án</data>
    </node>
    <node id="KHOAN_HONG">
      <data key="d0">được khoan hồng</data>
    </node>
    <node id="KHAC_PHUC_HAU_QUA">
      <data key="d0">tự nguyện sửa chữa, bồi thường thiệt hại hoặc khắc phục hậu quả</data>
    </node>
    <node id="PHAM_TOI_TRONG_LANH_THO_VN">
      <data key="d0">hành vi phạm tội hoặc hậu quả của hành vi phạm tội xảy ra tại vùng đặc quyền kinh tế hoặc thềm lục địa của Việt Nam</data>
    </node>
    <node id="AP_DUNG_BLHS">
      <data key="d0">chịu sự áp dụng của Bộ luật Hình sự</data>
    </node>
    <node id="MIEN_TRU_NGOAI_GIAO">
      <data key="d0">phạm tội trên lãnh thổ Việt Nam và thuộc đối tượng được hưởng quyền miễn trừ ngoại giao hoặc lãnh sự</data>
    </node>
    <node id="GIAI_QUYET_THEO_DIEU_UOC_QUOC_TE">
      <data key="d0">trách nhiệm hình sự được giải quyết theo điều ước quốc tế hoặc tập quán quốc tế</data>
    </node>
    <node id="KHONG_CO_DIEU_UOC_AP_DUNG">
      <data key="d0">điều ước quốc tế không quy định và không có tập quán quốc tế áp dụng</data>
    </node>
    <node id="GIAI_QUYET_NGOAI_GIAO">
      <data key="d0">trách nhiệm hình sự được giải quyết bằng con đường ngoại giao</data>
    </node>
    <node id="PHAM_TOI_NGOAI_LANH_THO">
      <data key="d0">có hành vi phạm tội ở ngoài lãnh thổ nước Cộng hòa xã hội chủ nghĩa Việt Nam và hành vi đó được Bộ luật Hình sự quy định là tội phạm</data>
    </node>
    <node id="CO_THE_BI_TRUY_CUU_TNHS">
      <data key="d0">có thể bị truy cứu trách nhiệm hình sự tại Việt Nam</data>
    </node>
    <node id="LUAT_CO_HIEU_LUC">
      <data key="d0">hành vi phạm tội được thực hiện trong thời gian điều luật đang có hiệu lực thi hành</data>
    </node>
    <node id="AP_DUNG_DIEU_LUAT">
      <data key="d0">được áp dụng điều luật đó</data>
    </node>
    <node id="LUAT_BAT_LOI">
      <data key="d0">hành vi phạm tội được thực hiện trước khi điều luật quy định tình tiết tăng nặng mới hoặc quy định khác không có lợi có hiệu lực thi hành</data>
    </node>
    <node id="KHONG_AP_DUNG_DIEU_LUAT">
      <data key="d0">không áp dụng điều luật đó</data>
    </node>
    <node id="LUAT_CO_LOI">
      <data key="d0">hành vi phạm tội được thực hiện trước khi điều luật xóa bỏ tội phạm, xóa bỏ hình phạt, quy định hình phạt nhẹ hơn, tình tiết giảm nhẹ mới hoặc quy định khác có lợi có hiệu lực thi hành</data>
    </node>
    <node id="CAU_THANH_TOI_PHAM">
      <data key="d0">thực hiện hành vi nguy hiểm cho xã hội được quy định trong Bộ luật Hình sự và hành vi đó xâm phạm các quan hệ xã hội được pháp luật hình sự bảo vệ</data>
    </node>
    <node id="BI_XU_LY_HINH_SU">
      <data key="d0">bị xử lý hình sự</data>
    </node>
    <node id="HANH_VI_KHONG_DANG_KE">
      <data key="d0">hành vi có dấu hiệu của tội phạm nhưng tính chất nguy hiểm cho xã hội không đáng kể</data>
    </node>
    <node id="KHONG_PHAI_TOI_PHAM">
      <data key="d0">không phải là tội phạm</data>
    </node>
    <node id="XU_LY_BIEN_PHAP_KHAC">
      <data key="d0">được xử lý bằng các biện pháp khác</data>
    </node>
    <node id="KHUNG_HINH_PHAT_DEN_3_NAM">
      <data key="d0">mức cao nhất của khung hình phạt là phạt tiền, cải tạo không giam giữ hoặc phạt tù đến 03 năm</data>
    </node>
    <node id="TOI_IT_NGHIEM_TRONG">
      <data key="d0">được phân loại là tội phạm ít nghiêm trọng</data>
    </node>
    <node id="KHUNG_HINH_PHAT_3_7_NAM">
      <data key="d0">mức cao nhất của khung hình phạt là từ trên 03 năm tù đến 07 năm tù</data>
    </node>
    <node id="TOI_NGHIEM_TRONG">
      <data key="d0">được phân loại là tội phạm nghiêm trọng</data>
    </node>
    <node id="KHUNG_HINH_PHAT_7_15_NAM">
      <data key="d0">mức cao nhất của khung hình phạt là từ trên 07 năm tù đến 15 năm tù</data>
    </node>
    <node id="TOI_RAT_NGHIEM_TRONG">
      <data key="d0">được phân loại là tội phạm rất nghiêm trọng</data>
    </node>
    <node id="KHUNG_HINH_PHAT_TREN_15_NAM">
      <data key="d0">mức cao nhất của khung hình phạt là từ trên 15 năm tù đến 20 năm tù, tù chung thân hoặc tử hình</data>
    </node>
    <node id="TOI_DAC_BIET_NGHIEM_TRONG">
      <data key="d0">được phân loại là tội phạm đặc biệt nghiêm trọng</data>
    </node>
    <node id="PHAN_LOAI_TOI_PHAM">
      <data key="d0">được phân loại theo tính chất và mức độ nguy hiểm cho xã hội tương ứng với khoản 1 Điều 9</data>
    </node>
    <node id="VO_Y_QUA_TU_TIN">
      <data key="d0">thấy trước hành vi của mình có thể gây ra hậu quả nguy hại cho xã hội nhưng cho rằng hậu quả đó sẽ không xảy ra hoặc có thể ngăn ngừa được</data>
    </node>
    <node id="VO_Y_PHAM_TOI">
      <data key="d0">vô ý phạm tội</data>
    </node>
    <node id="VO_Y_CAU_THA">
      <data key="d0">không thấy trước hành vi của mình có thể gây ra hậu quả nguy hại cho xã hội mặc dù phải thấy trước và có thể thấy trước hậu quả đó</data>
    </node>
    <node id="TU_DU_16">
      <data key="d0">đủ 16 tuổi trở lên</data>
    </node>
    <node id="TU_14_DEN_16_PHAM_TOI_DAC_BIET">
      <data key="d0">thực hiện tội phạm rất nghiêm trọng hoặc tội phạm đặc biệt nghiêm trọng thuộc các điều luật được quy định tại khoản 2 Điều 12</data>
    </node>
    <node id="MAT_NANG_LUC_DO_CHAT_KICH_THICH">
      <data key="d0">mất khả năng nhận thức hoặc khả năng điều khiển hành vi do dùng rượu, bia hoặc chất kích thích mạnh khác</data>
    </node>
    <node id="VAN_CHIU_TRACH_NHIEM_HINH_SU">
      <data key="d0">vẫn chịu trách nhiệm hình sự</data>
    </node>
    <node id="CHUAN_BI_PHAM_TOI">
      <data key="d0">chuẩn bị phạm tội giết người</data>
    </node>
    <node id="PHAM_TOI_CHUA_DAT">
      <data key="d0">thực hiện hành vi phạm tội chưa đạt</data>
    </node>
    <node id="LA_TOI_PHAM_CHUA_DAT">
      <data key="d0">phạm tội chưa đạt</data>
    </node>
    <node id="TU_Y_CHAM_DUT_PHAM_TOI">
      <data key="d0">tự mình không thực hiện tội phạm đến cùng mặc dù không có gì ngăn cản</data>
    </node>
    <node id="MIEN_TRACH_NHIEM_HINH_SU">
      <data key="d0">được coi là không có tội và được trả lại toàn bộ của đã dùng để đưa hối lộ</data>
    </node>
    <node id="CAU_THANH_TOI_PHAM_KHAC">
      <data key="d0">hành vi thực tế đã thực hiện có đủ yếu tố cấu thành của một tội khác</data>
    </node>
    <node id="CO_Y_CUNG_THUC_HIEN_TOI_PHAM">
      <data key="d0">cố ý cùng thực hiện một tội phạm</data>
    </node>
    <node id="DONG_PHAM">
      <data key="d0">đồng phạm</data>
    </node>
    <node id="PHAM_TOI_CO_TO_CHUC">
      <data key="d0">phạm tội có tổ chức</data>
    </node>
    <node id="DONG_PHAM_CO_TO_CHUC">
      <data key="d0">đồng phạm có tổ chức</data>
    </node>
    <node id="HANH_VI_VUOT_QUA_DONG_PHAM">
      <data key="d0">hành vi vượt quá do người thực hành thực hiện</data>
    </node>
    <node id="KHONG_CHIU_TRACH_NHIEM_HINH_SU">
      <data key="d0">không phải chịu trách nhiệm hình sự</data>
    </node>
    <node id="CHE_GIAU_TOI_PHAM">
      <data key="d0">che giấu tội phạm thuộc danh mục quy định</data>
    </node>
    <node id="CHE_GIAU_TOI_DAC_BIET_NGHIEM_TRONG">
      <data key="d0">che giấu tội xâm phạm an ninh quốc gia hoặc tội đặc biệt nghiêm trọng khác quy định tại Điều 389</data>
    </node>
    <node id="KHONG_TO_GIAC_TOI_PHAM">
      <data key="d0">biết rõ tội phạm đang được chuẩn bị, đang thực hiện hoặc đã thực hiện nhưng không tố giác</data>
    </node>
    <node id="DOI_TUONG_DUOC_MIEN_TO_GIAC">
      <data key="d0">không tố giác tội phạm</data>
    </node>
    <node id="KHONG_TO_GIAC_TOI_DAC_BIET_NGHIEM_TRONG">
      <data key="d0">không tố giác tội thuộc Chương XIII hoặc tội phạm đặc biệt nghiêm trọng</data>
    </node>
    <node id="NGUOI_BAO_CHUA_KHONG_TO_GIAC">
      <data key="d0">không tố giác tội phạm</data>
    </node>
    <node id="NGUOI_BAO_CHUA_KHONG_TO_GIAC_TOI_DAC_BIET">
      <data key="d0">không tố giác tội thuộc Chương XIII hoặc tội phạm đặc biệt nghiêm trọng do chính người mình bào chữa thực hiện mà biết rõ khi bào chữa</data>
    </node>
    <node id="SU_KIEN_BAT_NGO">
      <data key="d0">gây hậu quả nguy hại cho xã hội trong trường hợp không thể thấy trước hoặc không buộc phải thấy trước hậu quả của hành vi</data>
    </node>
    <node id="MAT_NANG_LUC_TRACH_NHIEM_HINH_SU">
      <data key="d0">mắc bệnh tâm thần hoặc bệnh khác làm mất khả năng nhận thức hoặc khả năng điều khiển hành vi</data>
    </node>
    <node id="PHONG_VE_CHINH_DANG">
      <data key="d0">chống trả một cách cần thiết người đang có hành vi xâm phạm quyền hoặc lợi ích chính đáng</data>
    </node>
    <node id="VUOT_QUA_PHONG_VE_CHINH_DANG">
      <data key="d0">vượt quá giới hạn phòng vệ chính đáng</data>
    </node>
    <node id="TINH_THE_CAP_THIET">
      <data key="d0">gây thiệt hại trong tình thế cấp thiết</data>
    </node>
    <node id="LA_TINH_THE_CAP_THIET">
      <data key="d0">ở trong tình thế cấp thiết</data>
    </node>
    <node id="VUOT_QUA_TINH_THE_CAP_THIET">
      <data key="d0">thiệt hại gây ra rõ ràng vượt quá yêu cầu của tình thế cấp thiết</data>
    </node>
    <node id="BAT_GIU_NGUOI_PHAM_TOI_DUNG_MUC">
      <data key="d0">để bắt giữ người thực hiện hành vi phạm tội và không còn cách nào khác ngoài việc sử dụng vũ lực cần thiết gây thiệt hại cho người bị bắt giữ</data>
    </node>
    <node id="VUOT_QUA_MUC_CAN_THIET_KHI_BAT_GIU">
      <data key="d0">sử dụng vũ lực rõ ràng vượt quá mức cần thiết khi bắt giữ người phạm tội</data>
    </node>
    <node id="RUI_RO_TRONG_NGHIEN_CUU_HOP_PHAP">
      <data key="d0">gây thiệt hại trong khi nghiên cứu, thử nghiệm hoặc áp dụng tiến bộ khoa học, kỹ thuật và công nghệ mới và đã tuân thủ đúng quy trình, quy phạm, áp dụng đầy đủ biện pháp phòng ngừa</data>
    </node>
    <node id="VI_PHAM_QUY_TRINH_AN_TOAN">
      <data key="d0">không áp dụng đúng quy trình, quy phạm hoặc không áp dụng đầy đủ biện pháp phòng ngừa mà gây thiệt hại</data>
    </node>
    <node id="THI_HANH_MENH_LENH_HOP_LE">
      <data key="d0">gây thiệt hại trong khi thi hành mệnh lệnh của người chỉ huy hoặc cấp trên trong lực lượng vũ trang nhân dân để thực hiện nhiệm vụ quốc phòng, an ninh và đã thực hiện đầy đủ quy trình báo cáo nhưng vẫn bị yêu cầu chấp hành mệnh lệnh</data>
    </node>
    <node id="RA_MENH_LENH_TRAI_PHAP_LUAT">
      <data key="d0">yêu cầu chấp hành mệnh lệnh sau khi người thi hành đã thực hiện đầy đủ quy trình báo cáo</data>
    </node>
    <node id="HET_THOI_HIEU_TRUY_CUU">
      <data key="d0">đã hết thời hiệu truy cứu trách nhiệm hình sự theo quy định của Bộ luật Hình sự</data>
    </node>
    <node id="KHONG_BI_TRUY_CUU_TNHS">
      <data key="d0">không bị truy cứu trách nhiệm hình sự</data>
    </node>
    <node id="THOI_HIEU_TRUY_CUU">
      <data key="d0">xác định thời hiệu truy cứu trách nhiệm hình sự</data>
    </node>
    <node id="THOI_HIEU_05_NAM">
      <data key="d0">thời hiệu thi hành bản án là 05 năm</data>
    </node>
    <node id="THOI_HIEU_10_NAM">
      <data key="d0">thời hiệu thi hành bản án là 10 năm</data>
    </node>
    <node id="THOI_HIEU_15_NAM">
      <data key="d0">thời hiệu thi hành bản án là 15 năm</data>
    </node>
    <node id="THOI_HIEU_20_NAM">
      <data key="d0">thời hiệu thi hành bản án là 20 năm</data>
    </node>
    <node id="TINH_TU_NGAY_PHAM_TOI">
      <data key="d0">thời hiệu được tính từ ngày tội phạm được thực hiện</data>
    </node>
    <node id="PHAM_TOI_MOI_TRONG_THOI_HIEU">
