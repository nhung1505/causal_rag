    <node id="XAM_PHAM_QUYEN_TU_DO_TIN_NGUONG_KHUNG_2">
      <data key="d0">xâm phạm quyền tự do tín ngưỡng, tôn giáo thuộc trường hợp quy định tại khoản 2 Điều 164</data>
