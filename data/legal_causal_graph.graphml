    <node id="PHAM_TOI_BUOC_THOI_VIEC_HOAC_SA_THAI_TRAI_PHAP_LUAT">
      <data key="d0">phạm tội buộc công chức, viên chức thôi việc hoặc sa thải người lao động trái pháp luật</data>
    </node>
    <node id="XAM_PHAM_QUYEN_HOI_HOP_LAP_HOI_TAI_PHAM">
      <data key="d0">dùng vũ lực, đe dọa dùng vũ lực hoặc thủ đoạn khác ngăn cản hoặc ép buộc người khác lập hội, hội họp hợp pháp, đã bị xử lý kỷ luật hoặc xử phạt vi phạm hành chính mà còn vi phạm</data>
    </node>
    <node id="CAI_TAO_HOAC_PHAT_TU_3_THANG_1_NAM">
