    <node id="ANH_HUONG_XAU_AN_NINH_KHU_VUC_BIEN_GIOI">
      <data key="d0">vi phạm quy chế khu vực biên giới gây ảnh hưởng xấu đến an ninh, trật tự, an toàn xã hội khu vực biên giới</data>
    </node>
    <node id="KET_AN_VI_PHAM_KHU_VUC_BIEN_GIOI">
